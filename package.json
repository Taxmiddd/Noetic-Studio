{
  "name": "noetic-studio",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "next build",
    "clean": "rimraf .next .open-next .wrangler",
    "build:cf": "npm run clean && opennextjs-cloudflare build",
    "dev": "next dev",
    "start": "next start",
    "lint": "eslint",
